{
    "name": "yiisoft/yii2-app-advanced-soa",
    "description": "Yii 2 Project Template on Advanced with Service Oriented Architecture",
    "keywords": ["yii2", "framework", "advanced", "project template", "soa"],
    "homepage": "https://www.yiiframework.com/",
    "type": "project",
    "license": "BSD-3-Clause",

    "support": {
        "issues": "https://github.com/yiisoft/yii2/issues?state=open",
        "forum": "https://www.yiiframework.com/forum/",
        "wiki": "https://www.yiiframework.com/wiki/",
        "irc": "ircs://irc.libera.chat:6697/yii",
        "source": "https://github.com/yiisoft/yii2"
    },

    "minimum-stability": "dev",
    "prefer-stable": true,

    "require": {
        "php": ">=8.0",
        "ext-pdo_pgsql": "*",
        "yiisoft/yii2": "~2.0.45",
        "yiisoft/yii2-bootstrap5": "~2.0.2",
        "yiisoft/yii2-symfonymailer": "~2.0.3",
        "twbs/bootstrap-icons": "~1.7",
        "vlucas/phpdotenv": "^5.5",
        "yiisoft/yii2-redis": "~2.0.0",
        "mikemadisonweb/yii2-rabbitmq": "^2.5",
        "mihaildev/yii2-ckeditor": "dev-master",
        "kartik-v/yii2-widget-select2": "^2.2@dev",
        "kartik-v/yii2-icons": "^1.4@dev",
        "andy87/knockknock": "^1.3 || dev-master",
        "andy87/yii2-migrate-architect": "^0.0.1 || dev-master",
        "andy87/lazy-load-trait": "dev-main"
    },

    "require-dev": {
        "yiisoft/yii2-debug": "~2.1.0",
        "yiisoft/yii2-gii": "~2.2.0",
        "yiisoft/yii2-faker": "~2.0.0",
        "behat/gherkin": "^4.16",
        "phpunit/phpunit": "^13",
        "codeception/codeception": "^5.3",
        "codeception/lib-innerbrowser": "^4.1",
        "codeception/module-asserts": "^3.0 || ^1.1",
        "codeception/module-yii2": "^2.0",
        "codeception/module-filesystem": "^3.0 || ^2.0 || ^1.1",
        "symfony/browser-kit": "^6.0 || >=2.7 <=4.2.4",
        "codeception/module-webdriver": "^4.0",
        "andy87/yii2-file-crafter": "dev-master"
    },

    "autoload": {
        "psr-4": {
            "yii2\\": "yii2/"
        }
    },

    "autoload-dev": {
        "psr-4": {
            "yii2\\common\\tests\\": [ "yii2/common/tests/", "yii2/common/tests/_support" ],
            "yii2\\backend\\tests\\": [ "yii2/backend/tests/", "yii2/backend/tests/_support" ],
            "yii2\\frontend\\tests\\": [ "yii2/frontend/tests/", "yii2/frontend/tests/_support" ]
        }
    },

    "config": {
        "allow-plugins": {
            "yiisoft/yii2-composer" : true
        },
        "process-timeout": 1800,
        "fxp-asset": {
            "enabled": false
        }
    },

    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ]
}
