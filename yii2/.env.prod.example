#
# Copy to yii2/.env.prod and replace every change-me value before production start.
#

#
# === DOMAIN ===
#
PROTOCOL=https
HOST=https://auditor.example.com

#
# === PROJECT ===
#
PROJECT_NAME="Site Auditor"
PROJECT_ID="site_auditor"

#
# === FRONTEND ===
#
APP_FRONTEND__NAME=${PROJECT_NAME}
APP_FRONTEND_ID=app-${PROJECT_ID}-frontend
APP_FRONTEND_CSRF_PARAM=csrf-${PROJECT_ID}-frontend
APP_FRONTEND_IDENTITY_COOKIE=cookie-${PROJECT_ID}-frontend
APP_FRONTEND_COOKIE_HTTP_ONLY_KEY=cookie-${PROJECT_ID}-frontend
APP_FRONTEND_COOKIE_VALIDATION_KEY=change-me-generate-strong-frontend-cookie-key
APP_FRONTEND_SESSION_NAME=session-${PROJECT_ID}-frontend
APP_FRONTEND_HOST=https://auditor.example.com

#
# === BACKEND ===
#
APP_BACKEND_NAME=${PROJECT_NAME}
APP_BACKEND_ID=app-${PROJECT_ID}-backend
APP_BACKEND_CSRF_PARAM=csrf-${PROJECT_ID}-backend
APP_BACKEND_IDENTITY_COOKIE=cookie-${PROJECT_ID}-backend
APP_BACKEND_COOKIE_HTTP_ONLY_KEY=cookie-${PROJECT_ID}-backend
APP_BACKEND_COOKIE_VALIDATION_KEY=change-me-generate-strong-backend-cookie-key
APP_BACKEND_SESSION_NAME=session-${PROJECT_ID}-backend
APP_BACKEND_HOST=https://admin.auditor.example.com
APP_BACKEND_BASE_URL=''

#
# === CONSOLE ===
#
APP_CONSOLE_ID=app-${PROJECT_ID}-console

#
# === DATABASE ===
#
DB_DRIVER=pgsql
DB_HOST=postgres
DB_NAME=site_auditor
DB_USERNAME=site_auditor
DB_PASSWORD=change-me-generate-strong-postgres-password
DB_CHARSET=utf8
DB_DSN_LOCAL=${DB_DRIVER}:host=${DB_HOST};dbname=${DB_NAME}

#
# === Redis / Queue ===
#
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DATABASE=0

#
# === Audit ===
#
AUDIT_DEFAULT_PAGE_LIMIT=20
AUDIT_MAX_PAGE_LIMIT=100
AUDIT_REQUEST_TIMEOUT=8
AUDIT_MAX_RESPONSE_BYTES=1048576
AUDIT_USER_AGENT="SiteAuditorBot/0.1 (+https://auditor.example.com)"

#
# === LLM ===
#
LLM_PROVIDER=mock
LLM_BASE_URL=""
LLM_API_KEY=""
LLM_MODEL=""
LLM_PROMPT_VERSION=audit-v1
LLM_TIMEOUT=30
LLM_RETRIES=2
LLM_RETRY_DELAY_MS=500

#
# === Mailer ===
#
MAILER_USE_FILE_TRANSPORT=false
MAILER_SCHEME=smtp
MAILER_HOST=smtp.example.com
MAILER_USERNAME=change-me
MAILER_PASSWORD=change-me
MAILER_PORT=465
MAILER_DSN=native://default
MAILER_VIEW_PATH=@common/mail

#
# === Reverse proxy / Traefik-compatible labels ===
#
SITE_AUDITOR_PUBLIC_NETWORK=site-auditor_public
SITE_AUDITOR_PUBLIC_NETWORK_EXTERNAL=false
TRAEFIK_ENABLE=false
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=letsencrypt
FRONTEND_HOSTNAME=auditor.example.com
BACKEND_HOSTNAME=admin.auditor.example.com
